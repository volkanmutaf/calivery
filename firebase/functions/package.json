{
    "name": "calivery-functions",
    "version": "1.0.0",
    "description": "Calivery Cloud Functions",
    "main": "lib/index.js",
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log",
        "test": "jest"
    },
    "engines": {
        "node": "20"
    },
    "dependencies": {
        "expo-server-sdk": "^6.1.0",
        "firebase-admin": "^12.0.0",
        "firebase-functions": "^4.5.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^20.10.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.3.0"
    },
    "private": true
}
