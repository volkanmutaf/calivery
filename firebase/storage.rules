rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isDriver() {
      return isAuthenticated();
    }
    
    // Photo uploads
    // Path: photos/{order_id}/{photo_type}_{timestamp}.jpg
    match /photos/{orderId}/{fileName} {
      // Anyone authenticated can read photos
      allow read: if isAuthenticated();
      
      // Only authenticated users can upload
      // In production, Cloud Functions should validate the upload
      allow create: if isAuthenticated() 
        && request.resource.size < 10 * 1024 * 1024  // Max 10MB
        && request.resource.contentType.matches('image/.*');
      
      // No updates or deletes allowed
      allow update, delete: if false;
    }
    
    // Profile photos
    match /profile_photos/{uid}/{fileName} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() 
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024  // Max 5MB
        && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }
  }
}
